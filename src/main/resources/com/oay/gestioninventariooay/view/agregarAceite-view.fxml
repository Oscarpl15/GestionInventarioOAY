<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.oay.gestioninventariooay.controller.AgregarAceiteController"
            prefWidth="600.0" stylesheets="@../css/estilos.css">

    <VBox spacing="15.0" AnchorPane.topAnchor="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0">
        <Label text="Añadir Nuevo Aceite/Taladrina" styleClass="titulo-formulario"/>

        <GridPane vgap="10.0" hgap="10.0">
            <columnConstraints>
                <ColumnConstraints minWidth="130.0"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Máquina Destino:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbMaquina" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200.0">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Torno Mazak"/>
                        <String fx:value="Fresa Mikron"/>
                        <String fx:value="Fresa Kondia"/>
                        <String fx:value="Fresa Puente"/>
                        <String fx:value="Sierra"/>
                    </FXCollections>
                </items>
            </ComboBox>

            <Label text="Tipo de Aceite:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtTipoAceite" promptText="Ej: Taladrina, Aceite Guías..." GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Uso Concreto:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtUso" promptText="Opcional" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Capacidad Garrafa (L):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="txtCapacidad" promptText="Ej: 25" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Stock (Garrafas):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="txtCantidad" promptText="Ej: 2" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Proveedor:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="txtEmpresa" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Precio Total (€):" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <TextField fx:id="txtPrecio" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
        </GridPane>

        <Separator/>

        <HBox spacing="15.0" alignment="CENTER_RIGHT">
            <Button text="Cancelar" onAction="#cancelar" styleClass="boton-cancelar"/>
            <Button text="Guardar Aceite" onAction="#guardar" styleClass="boton-accion-yellow"/>
        </HBox>
    </VBox>
</AnchorPane>
