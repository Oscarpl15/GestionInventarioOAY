<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.oay.gestioninventariooay.controller.FichaMaterialController"
            prefWidth="500.0" stylesheets="@../css/estilos.css">

    <VBox spacing="15.0" AnchorPane.topAnchor="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0">

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="lblTitulo" styleClass="titulo-formulario"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblModo" text="[SOLO LECTURA]" styleClass="label-modo-lectura"/>
        </HBox>

        <Separator/>

        <GridPane vgap="10.0" hgap="10.0">
            <columnConstraints>
                <ColumnConstraints minWidth="120.0"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Formato:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbCategoria" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="Tipo de Material:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbTipoMaterial" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="250.0"/>

            <Label text="Proveedor:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtEmpresa" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Precio Total (€):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="txtPrecio" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
        </GridPane>

        <Separator/>
        <Label text="Medidas y Especificaciones" styleClass="titulo-seccion"/>

        <GridPane fx:id="gridMedidas" vgap="10.0" hgap="10.0">
            <columnConstraints>
                <ColumnConstraints minWidth="120.0"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
        </GridPane>

        <Separator/>

        <VBox fx:id="panelStock" spacing="10" styleClass="panel-stock">
            <Label text="Ajuste de Cantidad / Stock" styleClass="titulo-stock"/>
            <HBox fx:id="boxControlesStock" spacing="10" alignment="CENTER_LEFT"/>
        </VBox>

        <HBox spacing="15.0" alignment="CENTER_RIGHT">
            <Button fx:id="btnEliminar" text="Eliminar Material" onAction="#eliminar" styleClass="boton-eliminar"/>
            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="btnCancelarEdicion" text="Cancelar Edición" onAction="#cancelarEdicion" styleClass="boton-cancelar" visible="false" managed="false"/>
            <Button fx:id="btnCerrar" text="Cerrar Ficha" onAction="#cerrar" styleClass="boton-cancelar"/>
            <Button fx:id="btnModificar" text="Modificar Datos" onAction="#toggleEdicion" styleClass="boton-lectura-activo"/>
        </HBox>
    </VBox>
</AnchorPane>