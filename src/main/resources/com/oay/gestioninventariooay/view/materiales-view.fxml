<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.oay.gestioninventariooay.controller.MaterialesController"
      spacing="15" styleClass="contenedor-principal">

    <BorderPane>
        <left>
            <HBox spacing="10">
                <ComboBox fx:id="cmbFiltroCategoria" prefWidth="150" promptText="Formato">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Todos"/>
                            <String fx:value="Redonda"/>
                            <String fx:value="Cuadrada"/>
                            <String fx:value="Plancha"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <ComboBox fx:id="cmbFiltroMaterial" prefWidth="150" promptText="Material"/>
            </HBox>
        </left>
        <right>
            <TextField fx:id="txtBuscar" promptText="🔍 Buscar por material..." prefWidth="200"/>
        </right>
    </BorderPane>

    <TableView fx:id="tablaMateriales" VBox.vgrow="ALWAYS" styleClass="striped, bordered">
        <columns>
            <TableColumn fx:id="colCategoria" text="Formato" prefWidth="100"/>
            <TableColumn fx:id="colTipo" text="Material" prefWidth="120"/>
            <TableColumn fx:id="colTamano" text="Tamaño (mm)" prefWidth="160"/>
            <TableColumn fx:id="colCantidad" text="Cantidad Total" prefWidth="130"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="+ AÑADIR MATERIAL" onAction="#nuevoMaterial" styleClass="boton-accion"/>
    </HBox>
</VBox>