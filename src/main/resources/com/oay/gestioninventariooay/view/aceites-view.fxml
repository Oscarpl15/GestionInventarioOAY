<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.oay.gestioninventariooay.controller.AceitesController"
      spacing="15" styleClass="contenedor-principal">

    <BorderPane>
        <left>
            <ComboBox fx:id="cmbFiltroMaquina" prefWidth="250" promptText="Filtrar por Máquina">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Todas"/>
                        <String fx:value="Torno Mazak"/>
                        <String fx:value="Fresa Mikron"/>
                        <String fx:value="Fresa Kondia"/>
                        <String fx:value="Fresa Puente"/>
                        <String fx:value="Sierra"/>
                    </FXCollections>
                </items>
            </ComboBox>
        </left>
        <right>
            <TextField fx:id="txtBuscar" promptText="🔍 Buscar por referencia..." prefWidth="200"/>
        </right>
    </BorderPane>

    <TableView fx:id="tablaAceites" VBox.vgrow="ALWAYS" styleClass="striped, bordered">
        <columns>
            <TableColumn fx:id="colMaquina" text="Máquina Destino" prefWidth="150"/>
            <TableColumn fx:id="colTipo" text="Tipo de Aceite" prefWidth="150"/>
            <TableColumn fx:id="colReferencia" text="Referencia" prefWidth="130"/>
            <TableColumn fx:id="colCapacidad" text="Garrafa/Bidón (L)" prefWidth="120"/>
            <TableColumn fx:id="colCantidad" text="Stock (Garrafas)" prefWidth="120"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="+ AÑADIR ACEITE" onAction="#nuevoAceite" styleClass="boton-accion"/>
    </HBox>
</VBox>
